# TCB 云托管环境变量（控制台「服务设置 → 环境变量」）
# 数据访问：Prisma + DATABASE_URL（官方 ORM → Prisma 模式），不使用 @cloudbase/node-sdk rdb()

# 必填：云开发 MySQL 连接串（控制台 Prisma 指引 → 内网地址）
# 示例：mysql://root:password@10.x.x.x:3306/simplemall
DATABASE_URL=mysql://user:password@内网主机:3306/simplemall

# 必填：Redis（云开发 Redis 或 TencentDB）
REDIS_URL=redis://:password@host:6379/0

JWT_SECRET=change-me-in-production
JWT_ADMIN_SECRET=change-me-admin-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# 对外 API 根地址（无尾斜杠），上传图片绝对 URL、CORS
PUBLIC_API_BASE=https://your-api-domain

CORS_ORIGINS=https://your-web-domain,https://your-admin-domain

PORT=80
HOST=0.0.0.0
NODE_ENV=production

# 多副本时建议单实例开启，或设为 false 后改用云函数定时触发
ENABLE_CRON=true

MOCK_PAY_SIGN_SECRET=dev-mock-sign-secret
