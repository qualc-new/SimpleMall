JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
MOCK_PAY_SIGN_SECRET=dev_mock_sign
ORDER_PAY_TIMEOUT_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
