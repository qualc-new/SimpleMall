# 由 ./dev.sh 首次启动时自动复制为 .env（若不存在）
# Docker Compose 默认账号 root/root，见项目根目录 docker-compose.yml

PORT=4000
# Docker Compose 默认 root/root；本机 MySQL 请改密码
DATABASE_URL=mysql://root:root@127.0.0.1:3306/simplemall
REDIS_URL=redis://localhost:6379
JWT_SECRET=simplemall_jwt_dev_secret_change_me
JWT_REFRESH_SECRET=simplemall_refresh_dev_secret_change_me
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
MOCK_PAY_SIGN_SECRET=dev_mock_sign
ORDER_PAY_TIMEOUT_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
