{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-start.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/guard-destructive-git.sh",
        "matcher": "git\\s+(push|reset|clean|checkout)",
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop-verify-reminder.sh",
        "loop_limit": 1
      }
    ]
  }
}
