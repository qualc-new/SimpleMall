# 复制为项目根目录 .env（CloudBase CLI 与静态构建读取，勿提交 .env）

# 云开发环境 ID
CLOUDBASE_ENV_ID=your-env-id

# 静态构建必填：云托管 simplemall-api 默认公网地址 + /api/v1|v2
# 示例：https://simplemall-api-xxxx.sh.run.tcloudbase.com/api/v1
NUXT_PUBLIC_API_BASE=https://your-cloudrun-domain.sh.run.tcloudbase.com/api/v1
VITE_API_BASE=https://your-cloudrun-domain.sh.run.tcloudbase.com/api/v1
VITE_API_V2_BASE=https://your-cloudrun-domain.sh.run.tcloudbase.com/api/v2

# 可选：与 NUXT_PUBLIC_API_BASE 等价简写
# TCB_API_BASE=https://your-cloudrun-domain.sh.run.tcloudbase.com/api/v1
