{
  "name": "simplemall",
  "version": "0.1.0",
  "private": true,
  "description": "轻量电商 Monorepo — Node API + Nuxt Web + React Admin",
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web dev:admin",
    "dev:api": "pnpm --filter @simplemall/api dev",
    "dev:web": "TMPDIR=/tmp TEMP=/tmp TMP=/tmp pnpm --filter @simplemall/web dev",
    "dev:admin": "pnpm --filter @simplemall/admin dev",
    "build": "pnpm --filter @simplemall/shared build && pnpm -r build",
    "build:tcb:api": "docker build -f deploy/tcb/Dockerfile -t simplemall-api .",
    "build:tcb:web": "pnpm --filter @simplemall/shared build && pnpm --filter @simplemall/web generate",
    "build:tcb:admin": "pnpm --filter @simplemall/shared build && pnpm --filter @simplemall/admin build",
    "build:tcb:static": "bash deploy/tcb/build-static.sh",
    "db:up": "docker compose up -d",
    "db:migrate": "pnpm --filter @simplemall/api prisma:migrate",
    "db:seed": "pnpm --filter @simplemall/api prisma:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "esbuild"
    ]
  }
}
